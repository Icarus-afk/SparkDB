# SparkDB Configuration
# Copy this file to .env and fill in your values.
# Environment variables override config.json values.

# REQUIRED: Set a strong, unique JWT signing secret (minimum 32 characters)
# If not set, an ephemeral secret is generated on each restart,
# which invalidates all existing tokens.
SPARKDB_AUTH_JWT_SECRET=

# REQUIRED in production: Enable TLS
# SPARKDB_TLS_ENABLED=true
# SPARKDB_TLS_CERT_FILE=/etc/sparkdb/sparkdb.crt
# SPARKDB_TLS_KEY_FILE=/etc/sparkdb/sparkdb.key

# Optional: Database encryption key (32-byte hex, generated via `sparkdb gen-key`)
# SPARKDB_ENCRYPTION_KEY=

# Server settings
# SPARKDB_SERVER_HOST=0.0.0.0
# SPARKDB_SERVER_PORT=9600

# Restrict CORS origins (comma-separated, default allows all)
# SPARKDB_SERVER_ALLOWED_ORIGINS=https://myapp.example.com

# Data directories
# SPARKDB_DATABASE_DATA_DIR=./data
# SPARKDB_BACKUP_DIR=./backups
